{
    "latex-workshop.latex.outDir": "output",

    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
            "-shell-escape",
            "-synctex=1",
            "-interaction=nonstopmode",
            "-file-line-error",
            "-pdf",
            "-outdir=output",
            "%DOC%"
            ],
            "env": {}
        }
    ],

    "workbench.colorCustomizations": {
    "editorLineNumber.foreground": "#d6d5d5",
    "editorLineNumber.activeForeground": "#bdbdbd"
},
    "editor.folding": false,
    "editor.glyphMargin": false,

    "editor.lineDecorationsWidth": 10,

    "[latex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop",
    "editor.lineHeight": 22,
    "editor.padding.top": 20,
    "editor.wordWrap": "on",
    "editor.fontSize": 16,
    "editor.scrollbar.horizontal": "hidden",
    "editor.overviewRulerBorder": false,
    "editor.scrollBeyondLastColumn": 0,
    "editor.lineNumbersMinChars": 6,
    },

    "window.autoDetectColorScheme": false,
    "workbench.colorTheme": "Solarized Light",

    "highlight.decorations": { "backgroundColor": "#ff9d00" },
    "highlight.regexes": {
        //"(.*\\n\\s*\\n\\s*\\n.*)": [{"backgroundColor": "#000000"}],
        "( \\\\ref{)": [{}],
        "(figure \\\\ref)": [{}],
        "(section \\\\ref)": [{}],
        "(chapter \\\\ref)": [{}],
        "(equation \\\\ref)": [{}],
        "(\\(\\\\eqref)": [{}],
        "(equation \\(\\\\eqref)": [{}],
        "(equation \\(\\\\ref)": [{}],
        "(?!%)(?:.){3000,}": [{}],
    },


    "ltex.completionEnabled": true,
    "ltex.enabled": [
        "bibtex",
        "latex",
        "context"
    ],
    "ltex.language": "en-US",

    "cSpell.enabledFileTypes": {
    "*": false,
    "markdown": false,
    "plaintext": false,
    "json": false,
    "jsonc": false,
    "yaml": false,
    "latex": true,
    "tex": true
    },
    "cSpell.words": [
        "Antitelephone",
        "desynchronization",
        "desynchronized",
        "doppler",
        "Ehrenfest",
        "emittance",
        "resetnumbers",
        "Rømer",
        "Stilwell",
        "Tachyonic",
        "Trouton",
        "unsynchronized"
    ],





}
